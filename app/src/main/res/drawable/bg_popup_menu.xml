<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted-glass background for popup / overflow menus: strongly rounded corners,
     semi-transparent surface and a faint outline. Replacing the menu background also
     suppresses the Material baseline elevation tint (the "purple" cast). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/popup_surface_translucent" />
    <corners android:radius="24dp" />
    <stroke
        android:width="1dp"
        android:color="@color/popup_stroke" />
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
