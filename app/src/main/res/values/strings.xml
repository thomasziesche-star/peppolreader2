    <!-- Help Manual -->
    <string name="help_title">Help &amp; Usage</string>
    <string name="help_message">Hi there, a few quick pointers...\n\n<b>Import invoices:</b>\nTap the + button and pick XML or PDF files (long-press for multi-select). You can also share files from your mail app to E-Invoice &amp; Peppol Reader.\n\n<b>ZUGFeRD &amp; Factur-X PDFs:</b>\nHybrid PDFs are detected automatically — the embedded invoice XML is extracted for you.\n\n<b>Supported formats:</b>\nUBL / Peppol BIS 3.0, XRechnung (UBL and CII), ZUGFeRD 1.x and 2.x, Factur-X.\n\n<b>Invoices vs. credit notes:</b>\nTold apart automatically — credit notes are flagged with a chip and shown with a negative amount.\n\n<b>View details:</b>\nTap a row to see the full invoice and generate a PDF.\n\n<b>Delete:</b>\nLong-press a row in the list.</string>

    <!-- Info Menu -->
    <string name="info_title">Info &amp; Disclaimer</string>
    <string name="info_message">This is a hobby project and NOT an official PEPPOL app.\n\nThe information provided is without warranty.\n\n<b>Accountant with beard</b></string>

