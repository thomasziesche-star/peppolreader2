<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Light -->
    <style name="Base.Theme.Peppolreaderfree" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        
        <!-- Secondary -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        
        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        
        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        
        <!-- Error -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>

        <!-- Popup / overflow menus: the custom frosted-glass background (see bg_popup_menu)
             replaces the tinted Material surface, removing the baseline "purple" cast. -->
        <item name="popupMenuStyle">@style/Widget.Peppol.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Peppol.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.Peppol.PopupMenu.Overflow</item>
    </style>

    <style name="Theme.Peppolreaderfree" parent="Base.Theme.Peppolreaderfree" />

    <!-- Frosted-glass popup menus: custom rounded translucent background (see bg_popup_menu). -->
    <style name="Widget.Peppol.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:popupElevation">4dp</item>
    </style>

    <style name="Widget.Peppol.PopupMenu.Overflow" parent="Widget.Material3.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:popupElevation">4dp</item>
        <item name="android:dropDownVerticalOffset">6dp</item>
    </style>

    <!-- Bottom sheets that contain text input (AI editor / AI chat). The dialog's own
         edge-to-edge mode otherwise swallows adjustResize, leaving inputs hidden behind the
         keyboard. Disabling it lets the sheet window resize so inputs stay above the IME. -->
    <style name="Theme.Peppol.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="enableEdgeToEdge">false</item>
    </style>
</resources>
