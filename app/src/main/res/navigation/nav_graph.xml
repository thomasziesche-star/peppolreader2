<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/invoiceListFragment">

    <fragment
        android:id="@+id/invoiceListFragment"
        android:name="com.example.peppolreaderfree.ui.InvoiceListFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_invoice_list">
        
        <action
            android:id="@+id/action_invoiceList_to_invoiceDetail"
            app:destination="@id/invoiceDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>
    
    <fragment
        android:id="@+id/invoiceDetailFragment"
        android:name="com.example.peppolreaderfree.ui.InvoiceDetailFragment"
        android:label="@string/invoice_detail"
        tools:layout="@layout/fragment_invoice_detail" />

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.peppolreaderfree.ui.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />



</navigation>