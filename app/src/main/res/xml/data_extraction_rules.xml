<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup/transfer rules for Android 12+ (API 31+).
   Invoice data is sensitive business data: excluded from cloud backup, but kept
   for local device-to-device transfer (stays on-device, never leaves to Google).
   Users back up invoices via the app's CSV/ZIP export.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="peppol_reader_database" />
        <exclude domain="database" path="peppol_reader_database-wal" />
        <exclude domain="database" path="peppol_reader_database-shm" />
        <exclude domain="file" path="attachments" />
    </cloud-backup>
    <!-- device-transfer omitted on purpose → everything is included for local
         phone-to-phone migration (no cloud involved). -->
</data-extraction-rules>
