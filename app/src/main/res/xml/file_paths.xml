<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Shared HTML invoice written to cacheDir root (InvoiceDetailFragment.shareAsHtml). -->
    <cache-path
        name="shared_files"
        path="." />
    <!-- Original/embedded PDFs opened from filesDir/attachments (openAttachment). -->
    <files-path
        name="internal_files"
        path="attachments/" />
    <!-- Generated ZUGFeRD PDFs from the Invoice Creator (filesDir/created_invoices). -->
    <files-path
        name="created_invoices"
        path="created_invoices/" />
</paths>
