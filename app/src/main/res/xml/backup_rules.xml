<?xml version="1.0" encoding="utf-8"?>
<!--
   Cloud-backup rules for API <= 30 (full-backup-content).
   Excludes sensitive invoice data (DB + attachments) from Auto Backup to Google.
   Users back up invoices via the app's CSV/ZIP export.
-->
<full-backup-content>
    <exclude domain="database" path="peppol_reader_database" />
    <exclude domain="database" path="peppol_reader_database-wal" />
    <exclude domain="database" path="peppol_reader_database-shm" />
    <exclude domain="file" path="attachments" />
</full-backup-content>
